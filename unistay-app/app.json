{
  "expo": {
    "name": "UniStay",
    "slug": "unistay-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "unistayapp",
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#00174b"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.unistayapp"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#00174b"
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow UniStay to access your photos to upload room images."
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "newArchEnabled": true
  }
}
